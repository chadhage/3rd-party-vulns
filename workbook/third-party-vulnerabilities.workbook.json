        "query": "{\"version\":\"MsGraphEndpoint/1.0\",\"data\":null,\"headers\":[],\"method\":\"GETARRAY\",\"path\":\"/v1.0/servicePrincipals?$filter=servicePrincipalType eq 'Application'&$select=displayName,appId,appOwnerOrganizationId,accountEnabled,servicePrincipalType,homepage,verifiedPublisher,publisherName,signInAudience\",\"urlParams\":[],\"transformers\":[{\"type\":\"jsonpath\",\"settings\":{\"columns\":[{\"path\":\"$.displayName\",\"columnid\":\"Application\"},{\"path\":\"$.appId\",\"columnid\":\"AppId\"},{\"path\":\"$.publisherName\",\"columnid\":\"Publisher\"},{\"path\":\"$.verifiedPublisher.displayName\",\"columnid\":\"VerifiedPublisher\"},{\"path\":\"$.appOwnerOrganizationId\",\"columnid\":\"OwnerTenant\"},{\"path\":\"$.signInAudience\",\"columnid\":\"Audience\"},{\"path\":\"$.accountEnabled\",\"columnid\":\"Enabled\"},{\"path\":\"$.homepage\",\"columnid\":\"Homepage\"}]}}]}",
